# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Your Supabase project URL (found in Settings > API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Your Supabase anon/public key (safe to use in frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ey...

# Your Supabase service role key (KEEP SECRET - for server-side only)
# Only use this for migration scripts or server-side operations
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.ey...

# Optional: Alternative naming (migration script supports both)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
